SUPABASE_URL= # Supabase project URL, or a postgresql:// connection URL for local development
SUPABASE_KEY= # Supabase database password or service key used to build the async PostgreSQL URL
REDIS_URL=redis://redis:6379/0 # Redis broker/result backend URL
OLLAMA_BASE_URL=http://localhost:11434 # Ollama HTTP API base URL
OLLAMA_MODEL=llama3 # Ollama model used for email generation
PROXY_URL= # Optional HTTP proxy URL for Playwright scraping
SMTP_HOST= # SMTP server host
SMTP_PORT=587 # SMTP server port
SMTP_USER= # SMTP username
SMTP_PASS= # SMTP password
SMTP_FROM_NAME= # Sender display name
SMTP_FROM_EMAIL= # Sender email address
DAILY_EMAIL_LIMIT=20000 # Maximum emails sent per day
SCRAPE_BATCH_SIZE=20 # Leads scraped per city per batch
SCRAPE_DELAY_MIN=2.0 # Minimum delay between scrape batches in seconds
SCRAPE_DELAY_MAX=5.0 # Maximum delay between scrape batches in seconds
CORS_ORIGINS=http://localhost:5173 # Comma-separated frontend origins allowed by CORS
